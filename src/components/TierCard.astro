---
import { sale, salePrice, type Tier } from "../data/pricing";

interface Props {
  tier: Tier;
  variant?: "compact" | "detailed";
}

const { tier, variant = "compact" } = Astro.props;
const { low, high } = salePrice(tier.fullLow, tier.fullHigh);
const showSale = sale.active;
const fmt = (n: number) => `$${n.toLocaleString()}`;
const previewIncludes = tier.includes.slice(0, 4);
---

{variant === "compact" ? (
  <a
    href={`/services#tier-${tier.id}`}
    class="block group rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-4 focus-visible:ring-offset-cream-2"
  >
    <article
      class:list={[
        "relative rounded-lg p-7 bg-white transition group-hover:-translate-y-0.5 group-hover:shadow-md",
        tier.featured ? "ring-2 ring-accent shadow-sm" : "ring-1 ring-stone-200",
      ]}
    >
      {tier.featured && (
        <p class="absolute -top-3 left-7 bg-accent text-white text-[10px] uppercase tracking-[0.18em] px-2 py-1 rounded-md font-semibold">
          Most popular
        </p>
      )}

      <p class="font-serif text-3xl italic text-stone-400">{tier.num}</p>
      <h3 class="mt-3 font-serif text-2xl font-medium group-hover:text-accent transition">
        {tier.name}
      </h3>

      <div class="mt-3">
        {showSale ? (
          <>
            <p class="text-accent font-serif text-2xl font-semibold">
              {fmt(low)}–{fmt(high)}
            </p>
            <p class="mt-1 text-sm text-stone-500">
              <span class="line-through">
                {fmt(tier.fullLow)}–{fmt(tier.fullHigh)}
              </span>
              <span class="ml-2 text-accent font-medium">
                save up to {fmt(tier.fullHigh - high)}
              </span>
            </p>
          </>
        ) : (
          <p class="font-serif text-2xl font-semibold">
            {fmt(tier.fullLow)}–{fmt(tier.fullHigh)}
          </p>
        )}
      </div>

      <p class="mt-5 text-sm text-stone-700 leading-relaxed">{tier.blurb}</p>

      <ul class="mt-5 space-y-2 text-sm text-stone-700">
        {previewIncludes.map((item) => (
          <li class="flex gap-2">
            <span class="text-accent mt-0.5">✓</span>
            <span>{item}</span>
          </li>
        ))}
      </ul>

      <p class="mt-6 text-sm text-accent italic group-hover:underline">
        See full {tier.name} breakdown →
      </p>
    </article>
  </a>
) : (
  <article
    class:list={[
      "relative rounded-lg p-7 bg-white transition hover:-translate-y-0.5 hover:shadow-md",
      tier.featured ? "ring-2 ring-accent shadow-sm" : "ring-1 ring-stone-200",
    ]}
  >
    {tier.featured && (
      <p class="absolute -top-3 left-7 bg-accent text-white text-[10px] uppercase tracking-[0.18em] px-2 py-1 rounded-md font-semibold">
        Most popular
      </p>
    )}

    <p class="font-serif text-3xl italic text-stone-400">{tier.num}</p>
    <h3 class="mt-3 font-serif text-2xl font-medium">{tier.name}</h3>

    <div class="mt-3">
      {showSale ? (
        <>
          <p class="text-accent font-serif text-2xl font-semibold">
            {fmt(low)}–{fmt(high)}
          </p>
          <p class="mt-1 text-sm text-stone-500">
            <span class="line-through">
              {fmt(tier.fullLow)}–{fmt(tier.fullHigh)}
            </span>
            <span class="ml-2 text-accent font-medium">
              save up to {fmt(tier.fullHigh - high)}
            </span>
          </p>
        </>
      ) : (
        <p class="font-serif text-2xl font-semibold">
          {fmt(tier.fullLow)}–{fmt(tier.fullHigh)}
        </p>
      )}
    </div>

    <p class="mt-5 text-sm text-stone-700 leading-relaxed">{tier.blurb}</p>

    <ul class="mt-5 space-y-2.5 text-sm text-stone-700">
      {tier.includes.map((item) => (
        <li class="flex gap-2">
          <span class="text-accent mt-0.5">✓</span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </article>
)}
