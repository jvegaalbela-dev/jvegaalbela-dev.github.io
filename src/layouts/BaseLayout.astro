---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SaleBanner from "../components/SaleBanner.astro";
import Analytics from "../components/Analytics.astro";
import { businessSchema, websiteSchema } from "../lib/schema";

// Resolve the critical font files to hashed asset URLs so we can preload them.
// Vite's `?url` import gives us the build-output URL, which changes on every
// build — preload markup stays correct without manual editing.
import interFont from "@fontsource-variable/inter/files/inter-latin-wght-normal.woff2?url";
import frauncesFont from "@fontsource-variable/fraunces/files/fraunces-latin-wght-normal.woff2?url";

interface Props {
  title: string;
  description?: string;
  showSaleBanner?: boolean;
  ogType?: "website" | "article";
  ogImage?: string;
  ogImageAlt?: string;
  additionalSchema?: object[];
}

const {
  title,
  description = "Custom Astro websites for small businesses in Rochester, NY (South Wedge). Fast, accessible, and built to be found on Google.",
  showSaleBanner = true,
  ogType = "website",
  ogImage = "/og-image.png",
  ogImageAlt = "jva.dev — A website that actually works for your business. Web design in South Wedge, Rochester, NY.",
  additionalSchema = [],
} = Astro.props;

const fullTitle = title.includes("jva.dev") || title.includes("JVA/dev")
  ? title
  : `${title} · jva.dev`;

const siteOrigin = Astro.site ?? new URL("https://jva-dev.com");
const canonical = new URL(Astro.url.pathname, siteOrigin).href;
const ogImageUrl = new URL(ogImage, siteOrigin).href;

const allSchemas = [businessSchema(), websiteSchema(), ...additionalSchema];

// Escape closing tags inside JSON-LD to prevent script injection.
const safeJson = (obj: object) =>
  JSON.stringify(obj).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="author" content="Jacobo Vega-Albela" />
    <meta name="theme-color" content="#234E70" />

    {/* Open Graph */}
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="jva.dev" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:image:type" content="image/png" />

    {/* Twitter Card */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{fullTitle}</title>

    {/* Self-hosted fonts via Fontsource. Preload the critical Latin subsets
        so the browser fetches them in parallel with the HTML parse, instead
        of waiting for the CSS to be parsed first (which delays text LCP).
        `crossorigin` is required even for same-origin font preloads, or the
        browser won't reuse the preloaded resource for the @font-face request. */}
    <link rel="preload" href={interFont} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={frauncesFont} as="font" type="font/woff2" crossorigin />

    {allSchemas.map((schema) => (
      <script type="application/ld+json" set:html={safeJson(schema)} />
    ))}

    <Analytics />
  </head>
  <body class="bg-cream text-stone-900 font-sans antialiased min-h-screen flex flex-col">
    {showSaleBanner && <SaleBanner />}
    <Header />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
