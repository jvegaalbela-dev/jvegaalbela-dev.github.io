---
import BaseLayout from "../layouts/BaseLayout.astro";
import { breadcrumbSchema, contactPageSchema } from "../lib/schema";

const FORMSPREE_ID = "xgodrblw";
const FORMSPREE_ACTION = `https://formspree.io/f/${FORMSPREE_ID}`;

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Contact", url: "/contact/" },
  ]),
  contactPageSchema(),
];
---

<BaseLayout
  title="Contact"
  description="Get in touch about a custom web design project. Based in Rochester's South Wedge, working with clients across the Greater Rochester area."
  additionalSchema={schemas}
>
  <section class="max-w-3xl mx-auto px-6 pt-20 pb-24">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-6">
      Get in touch
    </p>
    <h1
      class="font-serif text-5xl md:text-6xl font-medium tracking-tight leading-[1.05]"
    >
      Let's talk about your site.
    </h1>
    <p class="mt-8 text-lg text-stone-700 leading-relaxed max-w-2xl">
      Tell me a bit about your business and what you're hoping to fix or build. I usually reply within a business day with next steps and a rough scope.
    </p>

    <form
      id="contact-form"
      action={FORMSPREE_ACTION}
      method="POST"
      class="mt-12 grid gap-5"
    >
      <div class="grid md:grid-cols-2 gap-5">
        <label class="grid gap-2">
          <span class="text-sm font-medium text-stone-800">Your name</span>
          <input
            required
            type="text"
            name="name"
            data-fs-field
            class="bg-white rounded-md border border-stone-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent aria-[invalid=true]:border-red-400"
          />
          <span data-fs-error="name" class="fs-field-error"></span>
        </label>
        <label class="grid gap-2">
          <span class="text-sm font-medium text-stone-800">Email</span>
          <input
            required
            type="email"
            name="email"
            data-fs-field
            class="bg-white rounded-md border border-stone-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent aria-[invalid=true]:border-red-400"
          />
          <span data-fs-error="email" class="fs-field-error"></span>
        </label>
      </div>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-stone-800">
          Business name
          <span class="text-stone-500 font-normal">(optional)</span>
        </span>
        <input
          type="text"
          name="business"
          data-fs-field
          class="bg-white rounded-md border border-stone-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent aria-[invalid=true]:border-red-400"
        />
        <span data-fs-error="business" class="fs-field-error"></span>
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-stone-800">
          What are you looking for?
        </span>
        <select
          name="tier"
          data-fs-field
          class="bg-white rounded-md border border-stone-300 px-4 py-2.5 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent"
        >
          <option value="">Not sure yet</option>
          <option>Tier 1 — Basic Build</option>
          <option>Tier 2 — Build + SEO</option>
          <option>Tier 3 — Build + SEO + CMS</option>
          <option>A founding-client spot (75% off)</option>
        </select>
      </label>

      <label class="grid gap-2">
        <span class="text-sm font-medium text-stone-800">
          Tell me about your project
        </span>
        <textarea
          required
          name="message"
          rows="6"
          data-fs-field
          class="bg-white rounded-md border border-stone-300 px-4 py-3 focus:outline-none focus:ring-2 focus:ring-accent/50 focus:border-accent resize-y aria-[invalid=true]:border-red-400"
          placeholder="What's your business? What's not working about your current site (or do you have one)? What's the goal?"
        ></textarea>
        <span data-fs-error="message" class="fs-field-error"></span>
      </label>

      <!-- Honeypot for spam -->
      <input
        type="text"
        name="_gotcha"
        style="display:none"
        tabindex="-1"
        autocomplete="off"
      />

      <!-- Success and error display, populated by @formspree/ajax -->
      <div data-fs-success class="fs-success" role="status" aria-live="polite">
        <span class="fs-success-icon" aria-hidden="true">✓</span>
        <span class="fs-success-text"></span>
      </div>
      <div data-fs-error class="fs-form-error" role="alert"></div>

      <div class="flex flex-wrap items-center gap-x-6 gap-y-3 mt-2">
        <button
          type="submit"
          data-fs-submit-btn
          class="inline-flex items-center bg-accent text-white px-6 py-3 rounded-md text-sm font-medium hover:bg-accent-dark transition disabled:opacity-60 disabled:cursor-not-allowed"
        >
          Send message
        </button>
        <p class="text-sm text-stone-500">
          Or email
          <a
            class="text-accent hover:underline"
            href="mailto:jvegaalbela.dev@gmail.com"
          >
            jvegaalbela.dev@gmail.com
          </a>
          directly.
        </p>
      </div>
    </form>

    <p class="mt-16 text-sm text-stone-500">
      Based in Rochester's South Wedge neighborhood. Mostly working with clients across the Greater Rochester area, but remote-friendly.
    </p>
  </section>
</BaseLayout>

<style>
  /* Field-level error messages from @formspree/ajax */
  .fs-field-error {
    color: var(--color-red-700);
    font-size: 0.875rem;
    line-height: 1.4;
  }
  .fs-field-error:empty {
    display: none;
  }

  /* Form-level error from @formspree/ajax */
  .fs-form-error {
    background: var(--color-red-50);
    border: 1px solid var(--color-red-200);
    color: var(--color-red-900);
    border-radius: 0.375rem;
    padding: 0.875rem 1.25rem;
    font-size: 0.9375rem;
  }
  .fs-form-error:empty {
    display: none;
  }

  /* Success state — shown when @formspree/ajax populates .fs-success-text */
  .fs-success {
    display: none;
    align-items: flex-start;
    gap: 0.75rem;
    background: var(--color-emerald-50);
    border: 1px solid var(--color-emerald-200);
    color: var(--color-emerald-900);
    border-radius: 0.375rem;
    padding: 1rem 1.25rem;
  }
  .fs-success:has(.fs-success-text:not(:empty)) {
    display: flex;
  }
  .fs-success-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.5rem;
    height: 1.5rem;
    background: var(--color-emerald-600);
    color: white;
    border-radius: 9999px;
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .fs-success-text {
    line-height: 1.5;
  }
</style>

<script>
  import { initForm } from "@formspree/ajax";

  initForm({
    formElement: "#contact-form",
    formId: "xgodrblw",
  });

  // Send a GA4 `generate_lead` event when the contact form is submitted.
  // Fires after HTML5 validation passes (so empty / invalid clicks don't count),
  // and is gated on `window.gtag` so it's a no-op in dev or when GA is disabled.
  const form = document.getElementById("contact-form");
  form?.addEventListener("submit", () => {
    const gtag = (window as unknown as { gtag?: (...args: unknown[]) => void }).gtag;
    if (typeof gtag === "function") {
      gtag("event", "generate_lead", {
        form_id: "contact-form",
        form_destination: "formspree",
      });
    }
  });
</script>
