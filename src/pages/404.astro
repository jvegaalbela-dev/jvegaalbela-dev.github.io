---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Page not found" showSaleBanner={false}>
  <section class="max-w-3xl mx-auto px-6 py-32 text-center">
    <p class="font-serif text-7xl italic text-stone-300">404</p>
    <h1
      class="mt-6 font-serif text-4xl md:text-5xl font-medium tracking-tight"
    >
      Couldn't find that one.
    </h1>
    <p class="mt-6 text-stone-700">
      The page you're looking for might have moved, or maybe never existed.
    </p>
    <a
      href="/"
      class="inline-flex items-center mt-10 bg-accent text-white px-6 py-3 rounded-md text-sm font-medium hover:bg-accent-dark transition"
    >
      Back to home
    </a>
  </section>
</BaseLayout>
