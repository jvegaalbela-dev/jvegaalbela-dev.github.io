---
import BaseLayout from "../layouts/BaseLayout.astro";
import { tiers, retainers, hosting, sale, salePrice } from "../data/pricing";
import { serviceSchema, breadcrumbSchema } from "../lib/schema";

const fmt = (n: number) => `$${n.toLocaleString()}`;

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Services", url: "/services/" },
  ]),
  ...tiers.map((t) => serviceSchema(t)),
];
---

<BaseLayout
  title="Services & Pricing"
  description="Three-tier custom web design packages for Rochester businesses, with SEO and CMS options. Flat fees, no surprises. Founding-client pricing from $500."
  additionalSchema={schemas}
>
  <section class="max-w-6xl mx-auto px-6 pt-20 pb-16">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-6">
      Services & pricing
    </p>
    <h1
      class="font-serif text-5xl md:text-6xl font-medium tracking-tight leading-[1.05] max-w-3xl"
    >
      Three tiers. Flat prices. No surprises.
    </h1>
    <p class="mt-8 text-lg text-stone-700 max-w-2xl leading-relaxed">
      Pick the tier that fits where your business is now. Every site is a custom Astro build, fully responsive, with on-page SEO basics covered at every level.
    </p>
    {sale.active && (
      <div class="mt-10 inline-flex flex-wrap items-center gap-3 bg-accent/10 border border-accent/30 px-4 py-2 rounded-md">
        <span class="text-accent font-medium text-sm">
          {sale.label}
        </span>
        <span class="text-stone-700 text-sm">
          — {sale.remainingSlots} spots left at 75% off.
        </span>
      </div>
    )}
  </section>

  {tiers.map((t, i) => {
    const sp = salePrice(t.fullLow, t.fullHigh);
    return (
      <section
        class:list={[
          "border-t border-stone-200/80",
          i % 2 === 1 && "bg-cream-2/40",
        ]}
      >
        <div class="max-w-6xl mx-auto px-6 py-20 grid md:grid-cols-12 gap-10">
          <div class="md:col-span-5">
            <p class="font-serif text-5xl italic text-stone-300">{t.num}</p>
            <h2 class="mt-4 font-serif text-3xl md:text-4xl font-medium tracking-tight">
              {t.name}
            </h2>
            <div class="mt-6">
              {sale.active ? (
                <>
                  <p class="text-accent font-serif text-3xl font-semibold">
                    {fmt(sp.low)}–{fmt(sp.high)}
                  </p>
                  <p class="mt-1 text-sm text-stone-500">
                    <span class="line-through">
                      {fmt(t.fullLow)}–{fmt(t.fullHigh)}
                    </span>
                    <span class="ml-2 text-accent font-medium">
                      save up to {fmt(t.fullHigh - sp.high)}
                    </span>
                  </p>
                </>
              ) : (
                <p class="font-serif text-3xl font-semibold">
                  {fmt(t.fullLow)}–{fmt(t.fullHigh)}
                </p>
              )}
            </div>
            <p class="mt-6 text-stone-700 leading-relaxed">{t.blurb}</p>
            <a
              href="/contact"
              class="inline-flex items-center mt-8 bg-accent text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-accent-dark transition"
            >
              Start with {t.name} →
            </a>
          </div>
          <div class="md:col-span-7 md:pl-6">
            <p class="text-xs uppercase tracking-[0.15em] text-stone-500 mb-5">
              What's included
            </p>
            <ul class="space-y-3">
              {t.includes.map((item) => (
                <li class="flex gap-3 text-stone-800">
                  <span class="text-accent mt-1">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </section>
    );
  })}

  <!-- Post-launch plans: Hosting & Care + Retainers -->
  <section id="retainers" class="border-t border-stone-200/80">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <h2
        class="font-serif text-4xl md:text-5xl font-medium tracking-tight max-w-2xl mb-4"
      >
        After launch
      </h2>
      <p class="text-stone-600 max-w-2xl mb-12 leading-relaxed">
        Every post-launch site needs a place to live. Hosting & Care is the baseline. Retainers add ongoing edits, support, and reporting on top — and bundle Hosting & Care into the price.
      </p>

      <!-- Hosting & Care: the foundation -->
      <article class="bg-white rounded-lg ring-1 ring-stone-200 p-7 md:p-10 grid md:grid-cols-[1fr_2fr] gap-8 md:gap-12">
        <div>
          <p class="text-xs uppercase tracking-[0.15em] text-stone-500 mb-3">
            Foundation
          </p>
          <h3 class="font-serif text-2xl md:text-3xl font-medium">{hosting.name}</h3>
          <p class="mt-3 font-serif text-3xl font-semibold">
            ${hosting.price}<span class="text-base text-stone-500 font-sans">{hosting.unit}</span>
          </p>
          <p class="mt-5 text-sm text-stone-700 leading-relaxed">
            {hosting.description}
          </p>
          <p class="mt-4 text-sm text-stone-600 italic">
            Best for: {hosting.bestFor}
          </p>
        </div>
        <div>
          <p class="text-xs uppercase tracking-[0.15em] text-stone-500 mb-5">
            What's included
          </p>
          <ul class="space-y-2.5 text-sm text-stone-700">
            {hosting.includes.map((item) => (
              <li class="flex gap-2">
                <span class="text-accent mt-0.5">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </article>

      <!-- Bundling indicator -->
      <div class="my-14 flex items-center gap-4">
        <div class="h-px flex-1 bg-stone-300"></div>
        <p class="text-xs uppercase tracking-[0.18em] text-stone-600 font-medium text-center">
          All retainers include Hosting & Care
        </p>
        <div class="h-px flex-1 bg-stone-300"></div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">
        {retainers.map((r) => (
          <article
            class:list={[
              "relative rounded-lg p-7 bg-white transition hover:-translate-y-0.5 hover:shadow-md",
              r.featured ? "ring-2 ring-accent shadow-sm" : "ring-1 ring-stone-200",
            ]}
          >
            {r.featured && (
              <p class="absolute -top-3 left-7 bg-accent text-white text-[10px] uppercase tracking-[0.18em] px-2 py-1 rounded-md font-semibold">
                Most popular
              </p>
            )}
            <h3 class="font-serif text-2xl font-medium">{r.name}</h3>
            <p class="mt-2 font-serif text-3xl font-semibold">
              ${r.price}<span class="text-base text-stone-500 font-sans">{r.unit}</span>
            </p>
            <p class="mt-4 text-sm text-stone-600 italic">{r.bestFor}</p>
            <ul class="mt-5 space-y-2 text-sm text-stone-700">
              {r.includes.map((item) => (
                <li class="flex gap-2">
                  <span class="text-accent mt-0.5">✓</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </article>
        ))}
      </div>
      <p class="mt-10 text-sm text-stone-500 max-w-2xl">
        Not on a retainer? Post-launch changes can be billed at $85/hour as needed.
      </p>
    </div>
  </section>

  <!-- How this works -->
  <section class="border-t border-stone-200/80 bg-cream-2/40">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <h2
        class="font-serif text-3xl md:text-4xl font-medium tracking-tight mb-12"
      >
        How this works
      </h2>
      <dl class="grid md:grid-cols-2 gap-x-12 gap-y-10 max-w-4xl">
        <div>
          <dt class="font-semibold text-stone-900 mb-2">Flat fees, not hourly.</dt>
          <dd class="text-stone-700 leading-relaxed">
            Every project is quoted as a single number after a scoping conversation. 50% upfront, 50% on launch.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-stone-900 mb-2">
            Out-of-scope work is billed separately.
          </dt>
          <dd class="text-stone-700 leading-relaxed">
            Anything beyond the agreed scope (new sections, integrations, content collections) is quoted before starting — never as a surprise.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-stone-900 mb-2">
            Domain & third-party costs are pass-through.
          </dt>
          <dd class="text-stone-700 leading-relaxed">
            Domain registration, paid analytics tools, or premium service subscriptions are billed at cost directly to you.
          </dd>
        </div>
        <div>
          <dt class="font-semibold text-stone-900 mb-2">Pricing reflects scope.</dt>
          <dd class="text-stone-700 leading-relaxed">
            Within each tier's range, the final number depends on page count, content collection complexity, integration needs, and CMS schema depth.
          </dd>
        </div>
      </dl>
    </div>
  </section>

  <!-- CTA -->
  <section class="border-t border-stone-200/80">
    <div class="max-w-3xl mx-auto px-6 py-24 text-center">
      <h2 class="font-serif text-4xl font-medium tracking-tight">
        Ready to scope a project?
      </h2>
      <p class="mt-6 text-stone-700 leading-relaxed">
        Send a quick note about your business and what you're after. I'll come back with a scope and a flat price within a business day.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center mt-10 bg-accent text-white px-6 py-3 rounded-md text-sm font-medium hover:bg-accent-dark transition"
      >
        Get in touch →
      </a>
    </div>
  </section>
</BaseLayout>
