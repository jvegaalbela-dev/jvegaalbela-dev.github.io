---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import { breadcrumbSchema, creativeWorkSchema } from "../../lib/schema";

export async function getStaticPaths() {
  const items = await getCollection("work", ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Work", url: "/work/" },
    { name: item.data.title, url: `/work/${item.id}/` },
  ]),
  creativeWorkSchema(item),
];
---

<BaseLayout
  title={item.data.title}
  description={item.data.summary}
  ogType="article"
  additionalSchema={schemas}
>
  <article class="max-w-3xl mx-auto px-6 pt-10 md:pt-16 pb-24">
    <a
      href="/work"
      class="text-sm text-stone-500 hover:text-accent transition"
    >
      ← All work
    </a>

    <p class="mt-10 text-xs uppercase tracking-[0.18em] text-stone-500">
      {item.data.client}
    </p>
    <h1
      class="mt-3 font-serif text-5xl md:text-6xl font-medium tracking-tight leading-[1.05]"
    >
      {item.data.title}
    </h1>
    <p class="mt-8 text-xl text-stone-700 leading-relaxed">
      {item.data.summary}
    </p>

    {item.data.liveUrl && (
      <a
        href={item.data.liveUrl}
        target="_blank"
        rel="noopener"
        class="inline-flex items-center mt-8 bg-accent text-white px-5 py-2.5 rounded-md text-sm font-medium hover:bg-accent-dark transition"
      >
        Visit live site →
      </a>
    )}

    {item.data.coverImage && (
      <div class="mt-16">
        <Image
          src={item.data.coverImage}
          alt={item.data.title}
          class="w-full rounded-lg"
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 768px) 100vw, 768px"
        />
      </div>
    )}

    <div class="mt-16 prose">
      <Content />
    </div>

    <div
      class="mt-20 border-t border-stone-200 pt-10 flex flex-wrap justify-between gap-4 text-sm"
    >
      <a href="/work" class="text-accent hover:underline">← All work</a>
      {item.data.liveUrl && (
        <a
          href={item.data.liveUrl}
          target="_blank"
          rel="noopener"
          class="text-accent hover:underline"
        >
          Visit {item.data.client} →
        </a>
      )}
    </div>
  </article>
</BaseLayout>
