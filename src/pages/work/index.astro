---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import { breadcrumbSchema } from "../../lib/schema";

const workItems = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Work", url: "/work/" },
  ]),
];
---

<BaseLayout
  title="Recent Work"
  description="Selected case studies and recent custom Astro builds from Rochester web designer Jacobo Vega-Albela."
  additionalSchema={schemas}
>
  <section class="max-w-6xl mx-auto px-6 pt-10 md:pt-16 pb-24">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-6">Work</p>
    <h1
      class="font-serif text-5xl md:text-6xl font-medium tracking-tight leading-[1.05]"
    >
      Selected work.
    </h1>
    <p class="mt-8 text-lg text-stone-700 leading-relaxed max-w-2xl">
      A small collection of recent builds. JVA/dev is new — this is the start of the catalog.
    </p>

    {workItems.length === 0 ? (
      <p class="mt-16 text-stone-500">First case study coming soon.</p>
    ) : (
      <div class="mt-16 grid md:grid-cols-2 gap-8">
        {workItems.map((item) => (
          <a href={`/work/${item.id}`} class="block group">
            <article class="bg-white rounded-lg ring-1 ring-stone-200 overflow-hidden hover:-translate-y-0.5 hover:shadow-md transition">
              {item.data.coverImage ? (
                <Image
                  src={item.data.coverImage}
                  alt={item.data.title}
                  class="w-full aspect-[2/1] object-contain bg-cream-2"
                  widths={[400, 600, 800, 1200, 1600]}
                  sizes="(max-width: 768px) 100vw, 50vw"
                />
              ) : (
                <div class="w-full aspect-[2/1] bg-gradient-to-br from-cream-2 to-stone-200 flex items-center justify-center">
                  <p class="font-serif text-3xl italic text-stone-400">{item.data.client}</p>
                </div>
              )}
              <div class="p-6">
                <p class="text-xs uppercase tracking-[0.15em] text-stone-500">
                  {item.data.client}
                </p>
                <h3 class="mt-2 font-serif text-2xl font-medium tracking-tight group-hover:text-accent transition">
                  {item.data.title}
                </h3>
                <p class="mt-3 text-stone-700 leading-relaxed">
                  {item.data.summary}
                </p>
              </div>
            </article>
          </a>
        ))}
      </div>
    )}
  </section>
</BaseLayout>
