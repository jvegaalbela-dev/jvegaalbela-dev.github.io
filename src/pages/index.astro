---
import BaseLayout from "../layouts/BaseLayout.astro";
import TierCard from "../components/TierCard.astro";
import { tiers, sale } from "../data/pricing";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const workItems = (await getCollection("work", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Web Design in Rochester, NY"
  description="Custom Astro websites for small businesses in Rochester, NY (South Wedge). Fast, accessible, built to rank on Google. Founding clients at 75% off."
>
  <!-- Hero -->
  <section class="max-w-6xl mx-auto px-6 pt-10 md:pt-16 pb-24">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-10">
      Web design · South Wedge, Rochester, NY
    </p>
    <h1
      class="font-serif text-4xl sm:text-5xl md:text-7xl font-medium tracking-tight leading-tight md:leading-[1.02] max-w-4xl"
    >
      A website that
      <span class="italic relative whitespace-nowrap text-accent">
        actually works
        <svg
          class="absolute -bottom-1 md:-bottom-3 left-0 w-full"
          viewBox="0 0 300 12"
          fill="none"
          preserveAspectRatio="none"
          aria-hidden="true"
        >
          <path
            d="M2 8 C 60 3, 160 3, 298 7"
            stroke="currentColor"
            stroke-width="3"
            stroke-linecap="round"
          />
        </svg>
      </span>
      <br />for your business.
    </h1>
    <p class="mt-12 text-lg text-stone-700 max-w-2xl leading-relaxed">
      Custom-built, lightning fast, and easy for new customers to find on
      Google. For local businesses ready to stop fighting their website.
    </p>
    <div class="mt-10 flex flex-wrap gap-3">
      <a
        href="/contact"
        class="inline-flex items-center bg-accent text-white px-6 py-3 rounded-md text-sm font-medium hover:bg-accent-dark transition"
      >
        Start a project
      </a>
      <a
        href="/services"
        class="inline-flex items-center border border-stone-400 px-6 py-3 rounded-md text-sm font-medium hover:bg-white transition"
      >
        See pricing
      </a>
    </div>
  </section>

  <!-- Founding client callout -->
  {sale.active && (
    <section class="border-y border-stone-200/80 bg-white/40">
      <div class="max-w-6xl mx-auto px-6 py-14 grid md:grid-cols-[auto_1fr] gap-x-12 gap-y-4 items-center">
        <p class="font-serif text-5xl md:text-6xl text-accent font-medium tracking-tight whitespace-nowrap">
          75% off.
        </p>
        <div>
          <p class="font-semibold text-stone-900 mb-2">
            Founding client pricing — {sale.remainingSlots} spots only.
          </p>
          <p class="text-stone-700 leading-relaxed max-w-2xl">
            {sale.longBlurb}
          </p>
        </div>
      </div>
    </section>
  )}

  <!-- Tiers -->
  <section class="bg-cream-2/60">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <h2
        class="font-serif text-4xl md:text-5xl font-medium tracking-tight max-w-2xl mb-5"
      >
        Three ways to work together.
      </h2>
      <p class="text-stone-600 max-w-xl mb-12 leading-relaxed">
        Flat project fees, scoped after a conversation. No hourly clock-watching, no surprises.
      </p>
      <div class="grid md:grid-cols-3 gap-6">
        {tiers.map((t) => <TierCard tier={t} variant="compact" />)}
      </div>
      <p class="mt-10 text-sm text-stone-500 max-w-xl">
        After launch: Hosting & Care from $35/mo, or full retainers from $75/mo with hosting included.
        <a href="/services#retainers" class="text-accent hover:underline">
          See all plans →
        </a>
      </p>
    </div>
  </section>

  <!-- Proof / Recent work -->
  <section id="work" class="border-t border-stone-200/70">
    <div class="max-w-6xl mx-auto px-6 py-24">
      <h2 class="font-serif text-4xl md:text-5xl font-medium tracking-tight mb-3">
        Recent work
      </h2>

      {workItems.length === 0 ? (
        <>
          <p class="text-stone-600 max-w-xl mb-12 leading-relaxed">
            Case studies coming soon — JVA/dev is new, and the work is in the pipeline.
          </p>
          <div class="border border-dashed border-stone-300 rounded-lg p-10 bg-white/40 max-w-2xl">
            <p class="text-stone-700">
              Want your project featured here?
              <a href="/contact" class="text-accent font-medium hover:underline">
                Get in touch
              </a>
              — there are {sale.remainingSlots} founding-client spots left.
            </p>
          </div>
        </>
      ) : (
        <>
          <p class="text-stone-600 max-w-xl mb-12 leading-relaxed">
            A small selection of recent builds.
          </p>
          <div class="grid md:grid-cols-2 gap-8">
            {workItems.slice(0, 4).map((item) => (
              <a href={`/work/${item.id}`} class="block group">
                <article class="bg-white rounded-lg ring-1 ring-stone-200 overflow-hidden hover:-translate-y-0.5 hover:shadow-md transition">
                  {item.data.coverImage ? (
                    <Image
                      src={item.data.coverImage}
                      alt={item.data.title}
                      class="w-full aspect-[2/1] object-contain bg-cream-2"
                      widths={[400, 600, 800, 1200, 1600]}
                      sizes="(max-width: 768px) 100vw, 50vw"
                    />
                  ) : (
                    <div class="w-full aspect-[2/1] bg-gradient-to-br from-cream-2 to-stone-200 flex items-center justify-center">
                      <p class="font-serif text-3xl italic text-stone-400">{item.data.client}</p>
                    </div>
                  )}
                  <div class="p-6">
                    <p class="text-xs uppercase tracking-[0.15em] text-stone-500">
                      {item.data.client}
                    </p>
                    <h3 class="mt-2 font-serif text-2xl font-medium tracking-tight group-hover:text-accent transition">
                      {item.data.title}
                    </h3>
                    <p class="mt-3 text-stone-700 leading-relaxed">
                      {item.data.summary}
                    </p>
                  </div>
                </article>
              </a>
            ))}
          </div>
        </>
      )}
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="border-t border-stone-200/70 bg-accent text-white">
    <div class="max-w-6xl mx-auto px-6 py-20 text-center">
      <h2
        class="font-serif text-4xl md:text-5xl font-medium tracking-tight max-w-2xl mx-auto"
      >
        Ready for a website that pulls its weight?
      </h2>
      <p class="mt-6 max-w-xl mx-auto opacity-90 leading-relaxed">
        Tell me a bit about your business and what's not working. I'll come back with a scope and a flat price within a business day.
      </p>
      <a
        href="/contact"
        class="inline-flex items-center mt-10 bg-white text-accent px-6 py-3 rounded-md text-sm font-medium hover:bg-cream transition"
      >
        Start a project →
      </a>
    </div>
  </section>
</BaseLayout>
