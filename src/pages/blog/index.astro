---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { breadcrumbSchema } from "../../lib/schema";

const allPosts = await getCollection("posts", ({ data }) => !data.draft);
const posts = allPosts.sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const fmtDate = (d: Date) =>
  d.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });

const schemas = [
  breadcrumbSchema([
    { name: "Home", url: "/" },
    { name: "Writing", url: "/blog/" },
  ]),
];
---

<BaseLayout
  title="Writing"
  description="Plain-English writing on local SEO, Astro builds, and what it actually takes to run a small business website. From a Rochester web designer."
  additionalSchema={schemas}
>
  <section class="max-w-3xl mx-auto px-6 pt-10 md:pt-16 pb-24">
    <p class="text-xs uppercase tracking-[0.18em] text-stone-500 mb-6">
      Writing
    </p>
    <h1
      class="font-serif text-5xl md:text-6xl font-medium tracking-tight leading-[1.05]"
    >
      Notes from the workshop.
    </h1>
    <p class="mt-8 text-lg text-stone-700 leading-relaxed max-w-2xl">
      Plain-English thoughts on local SEO, Astro builds, and what it actually takes to run a small business website.
    </p>

    <div class="mt-16">
      {posts.length === 0 ? (
        <p class="text-stone-500">First post coming soon.</p>
      ) : (
        <ul class="divide-y divide-stone-200">
          {posts.map((post) => (
            <li class="py-8">
              <a href={`/blog/${post.id}`} class="block group">
                <p class="text-sm text-stone-500">
                  {fmtDate(post.data.pubDate)}
                </p>
                <h2 class="font-serif text-2xl md:text-3xl font-medium tracking-tight mt-2 group-hover:text-accent transition">
                  {post.data.title}
                </h2>
                <p class="mt-3 text-stone-700 leading-relaxed">
                  {post.data.description}
                </p>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>
  </section>
</BaseLayout>
